FLASK_HOST=0.0.0.0
FLASK_PORT=5000
DATABASE_URL=sqlite:///database.db
API_KEY=

CAMERA_INDEX=0
CAMERA_WIDTH=640
CAMERA_HEIGHT=480
CAMERA_FPS=20
CAMERA_BACKEND=auto
CAMERA_FORCE_MJPEG=1
CAMERA_OPEN_RETRIES=3
CAMERA_READ_RETRY=2

CHALLENGE_TIMEOUT_SECONDS=12
MAX_BLINK_FRAMES=30

# Servo tuning (adjust for your hardware)
SERVO_MIN_DUTY=2.5
SERVO_MAX_DUTY=12.5
SERVO_LOCK_ANGLE=0
SERVO_UNLOCK_ANGLE=90

# Repeat violation policy
REPEAT_WINDOW_MINUTES=10
REPEAT_THRESHOLD=5
VIOLATION_CAPTURE_COUNT=3

# LCD I2C address (leave empty for auto-detect 0x27/0x3F)
LCD_I2C_ADDR=
